<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AparellsCAP"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/ics_blue"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Creat per Antonio Prados Muñoz / EAP St Antoni"
        android:textSize="16sp"
        android:textColor="@color/text_black"
        android:layout_marginBottom="16dp"/>

    <!-- Nuevos campos para versión y fecha -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Versión: --"
        android:textSize="14sp"
        android:textColor="@color/ics_light_blue"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvBuildDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Compilado: --"
        android:textSize="14sp"
        android:textColor="@color/ics_light_blue"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registro de Equipos"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/ics_blue"
        android:padding="12dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnListado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Listado de Equipos"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/ics_blue"
        android:padding="12dp"/>
</LinearLayout>
