<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Llistat d'equips"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/ics_blue"
        android:padding="16dp"
        android:gravity="center"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ics_light_blue"
        android:alpha="0.3"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:baselineAligned="false">

        <Button
            android:id="@+id/btnExportar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Exporta"
            android:textColor="@color/white"
            android:backgroundTint="@color/ics_blue"
            android:layout_marginEnd="4dp"
            android:padding="12dp"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/btnExportarTxt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Exporta TXT"
            android:textColor="@color/white"
            android:backgroundTint="@color/ics_blue"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:padding="12dp"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/btnSalir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Surt"
            android:textColor="@color/white"
            android:backgroundTint="@color/ics_blue"
            android:layout_marginStart="4dp"
            android:padding="12dp"
            android:textSize="14sp"/>

    </LinearLayout>
</LinearLayout>
